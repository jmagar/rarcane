{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.dinglebear/arcane-rmcp",
  "title": "Arcane RMCP",
  "description": "Rust MCP server and CLI for Arcane Docker and container management.",
  "version": "0.4.3",
  "websiteUrl": "https://github.com/jmagar/arcane-rmcp",
  "repository": {
    "url": "https://github.com/jmagar/arcane-rmcp",
    "source": "github",
    "id": "1247261735"
  },
  "icons": [
    {
      "src": "https://avatars.githubusercontent.com/u/38927646?v=4",
      "mimeType": "image/png",
      "sizes": [
        "460x460"
      ],
      "theme": "dark"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "arcane-rmcp",
      "version": "0.4.3",
      "runtimeHint": "npx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "Run Arcane RMCP over stdio.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "isRepeated": false
        }
      ],
      "environmentVariables": [
        {
          "name": "RARCANE_API_URL",
          "description": "Arcane API base URL.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "placeholder": "https://arcane.example.com"
        },
        {
          "name": "RARCANE_API_KEY",
          "description": "Arcane API key or bearer token.",
          "format": "string",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "ARCANE_RMCP_VERSION",
          "description": "Optional GitHub release tag override for the downloaded Arcane RMCP binary.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "vX.Y.Z"
        },
        {
          "name": "ARCANE_RMCP_REPO",
          "description": "Optional GitHub owner/repo override for release asset downloads.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "jmagar/arcane-rmcp",
          "placeholder": "jmagar/arcane-rmcp"
        },
        {
          "name": "ARCANE_RMCP_RELEASE_BASE_URL",
          "description": "Optional release download base URL override.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "RUST_LOG",
          "description": "Tracing filter for Arcane RMCP logs.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "info",
          "placeholder": "info"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "namespace": "ai.dinglebear",
      "dnsDomain": "dinglebear.ai",
      "distribution": {
        "npm": "arcane-rmcp@0.4.3",
        "nodePackage": "arcane-rmcp"
      },
      "buildInfo": {
        "version": "0.4.3",
        "repository": "https://github.com/jmagar/arcane-rmcp"
      }
    }
  }
}
