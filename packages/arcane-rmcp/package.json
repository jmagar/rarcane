{
  "name": "arcane-rmcp",
  "version": "0.4.3",
  "description": "Node launcher for the Arcane Rust MCP server and rarcane CLI for Docker/container management.",
  "license": "MIT",
  "homepage": "https://github.com/jmagar/arcane-rmcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmagar/arcane-rmcp.git",
    "directory": "packages/arcane-rmcp"
  },
  "bugs": {
    "url": "https://github.com/jmagar/arcane-rmcp/issues"
  },
  "bin": {
    "rarcane": "bin/rarcane.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "scripts": {
    "prepack": "node scripts/sync-readme.js",
    "postinstall": "node scripts/install.js",
    "test": "node --test",
    "check": "node --check bin/rarcane.js && node --check scripts/install.js && node --check lib/platform.js && node --check scripts/sync-readme.js && node --check scripts/check-package.js && node scripts/check-package.js",
    "prepublishOnly": "node scripts/check-package.js --release"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "rmcp",
    "rust",
    "arcane",
    "docker",
    "containers",
    "docker-management",
    "homelab",
    "cli",
    "claude-code",
    "codex",
    "gemini",
    "automation",
    "oauth",
    "http-server",
    "stdio"
  ],
  "mcpName": "ai.dinglebear/arcane-rmcp",
  "author": {
    "name": "dinglebear.ai",
    "url": "https://dinglebear.ai"
  },
  "devDependencies": {
    "jsonpath-plus": "^10.3.0"
  }
}
